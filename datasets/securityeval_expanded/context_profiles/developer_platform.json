{
  "application_type": "developer_platform",
  "protected_assets": [
    "source_code",
    "api_tokens",
    "build_artifacts",
    "repository_metadata"
  ],
  "user_roles": [
    "developer",
    "maintainer",
    "organization_admin",
    "ci_service_account"
  ],
  "authorization_rules": [
    "developers may access repositories they are assigned to",
    "maintainers may manage project settings",
